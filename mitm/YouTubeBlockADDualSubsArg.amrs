# YouTube 去广告 + DualSubs 字幕翻译 Arg - Anywhere MITM RuleSet
# 上游: Maasea/sgmodule + DualSubs/YouTube（作者 VirgilClyne）。

name = YouTube去广告+DualSubs Arg
hostname = youtubei.googleapis.com, googlevideo.com, www.youtube.com, m.youtube.com, tv.youtube.com

[Parameter]
1, 0, subtitle_type, [字幕] 启用类型, 请选择要使用的字幕，双语字幕将使用您选择类型呈现。, Translate, "[Translate, Official]"
1, 0, auto_cc, [字幕] 自动显示, 是否总是自动开启字幕显示。, true, "[true, false]"
1, 0, show_only_auto_translation, [翻译器] 只显示自动翻译字幕, 是否仅显示自动翻译字幕，不显示源语言字幕。, false, "[false, true]"

[Rule]

0, 100, ^https://[^/]+/initplayback.*[?&]oad(?:[=&]|$), 
0, 100, ^https://[^/]+/youtubei/v1/(?:browse|next|search|reel/reel_watch_sequence|guide|account/get_setting)(?:\?|$), 
0, 100, ^https://(?:(?:www|m|tv)\.youtube\.com|youtubei\.googleapis\.com)/youtubei/v1/(?:player|get_watch)(?:\?|$), 
0, 0, ^https://((?:www|m)\.youtube\.com/api/timedtext\?)([^#]+)&tlang=([^&#]+)&([^#]*)(#.*)?$, 0, https://$1$2&$4&subtype=Translate$5
0, 0, ^https://((?:www|m)\.youtube\.com/api/timedtext\?)([^#]+)&tlang=([^&#]+)(#.*)?$, 0, https://$1$2&subtype=Translate$4
0, 0, ^https://((?:www|m)\.youtube\.com/api/timedtext\?)tlang=([^&#]+)&([^#]*)(#.*)?$, 0, https://$1$3&subtype=Translate$4
0, 0, ^https://((?:www|m)\.youtube\.com/api/timedtext\?)tlang=([^&#]+)(#.*)?$, 0, https://$1subtype=Translate$3
1, 100, ^https://(?:www|m)\.youtube\.com/api/timedtext(?:\?|$), 
1, 100, ^https://[^/]+/youtubei/v1/(?:browse|next|player|search|reel/reel_watch_sequence|guide|account/get_setting|get_watch)(?:\?|$), 
