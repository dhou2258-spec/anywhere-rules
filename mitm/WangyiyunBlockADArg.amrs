[Rule]
0, 0, ^https?://httpdns\.music\.163\.com(?:[/:?]|$), 2, {}
0, 0, ^https://[^/]+/x?e?api/ad(?:[/?].*|$), 2, {}
0, 0, ^https://[^/]+/w?e?api/(?:side-bar/mini-program/music-service/account|delivery/(?:batch-deliver|deliver)|moment/tab/info/get|yunbei/account/entrance/get)(?:\?|$), 2, {}
