# iRingo Maps Arg - Anywhere MITM RuleSet
# 上游: NSRingo/GeoServices（作者 VirgilClyne；iRingo Maps v4.6.1）。

name = iRingo Maps Arg
hostname = configuration.ls.apple.com, gspe35-ssl.ls.apple.com

[Parameter]
1, 0, geo_country, "[动态配置] 资源清单国家或地区代码", 影响地图整体配置内容和服务。, CN, "[CN, AUTO, HK, TW, SG, US, JP, AU, GB, KR, CA, IE]"
1, 0, dispatcher, "[URL信息集] 调度器", 地点数据接口。, AutoNavi, "[AutoNavi, AUTO, Apple]"
1, 0, directions, "[URL信息集] 导航与 ETA", "导航与 ETA 服务接口。", AutoNavi, "[AutoNavi, AUTO, Apple]"
1, 0, rap, "[URL信息集] 评分和照片", 评分和照片服务接口。, Apple, "[Apple, AUTO, AutoNavi]"
1, 0, location_shift, "[URL信息集] 定位漂移", 定位漂移修正服务接口。, AUTO, "[AUTO, AutoNavi, Apple]"
1, 0, earth_tiles, "[瓦片数据集] 地球图像", 影响地球视图下行政区划和地貌等信息。, AUTO, "[AUTO, AutoNavi, Apple]"
1, 0, roads_tiles, "[瓦片数据集] 道路图像与四处看看", 影响卫星视图下的道路图像与四处看看可用路段。, AUTO, "[AUTO, CN, XX]"
1, 0, satellite_tiles, "[瓦片数据集] 卫星图像", "影响 2D 卫星图像版本。", AUTO, "[AUTO, CN, XX]"
1, 0, log_level, "[调试] 日志等级", 选择脚本日志的输出等级。, WARN, "[WARN, OFF, ERROR, INFO, DEBUG, ALL]"

[Rule]
0, 2, ^https://[^/]+/geo_manifest/dynamic/config(?:\?|$), if-none-match
0, 100, ^https://[^/]+/geo_manifest/dynamic/config(?:\?|$), 
1, 100, ^https://[^/]+/(?:config/defaults|geo_manifest/dynamic/config)(?:\?|$), 
