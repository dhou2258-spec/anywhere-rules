1, 5, ^https://[^/]+/api/sns/v\d+/search/trending(?:\?|$), replace, $.data.hint_word, {}
1, 5, ^https://[^/]+/api/sns/v\d+/system_service/config(?:\?|$), delete, $.data.app_theme
1, 5, ^https://[^/]+/api/sns/v\d+/system_service/config(?:\?|$), delete, $.data.loading_img
1, 5, ^https://[^/]+/api/sns/v\d+/system_service/config(?:\?|$), delete, $.data.splash
1, 5, ^https://[^/]+/api/sns/v\d+/system_service/config(?:\?|$), delete, $.data.store
1, 5, ^https://[^/]+/api/sns/v\d+/note/widgets(?:\?|$), delete, $.data.cooperate_binds
