# Spotify 解锁/去广告 - Anywhere MITM RuleSet

name = Spotify解锁
hostname = spclient.wg.spotify.com, spotify.com

0, 2, ^/user-customization-service/v1/customize(?:\?|$), if-none-match
0, 2, ^/(?:bootstrap/v1/bootstrap|user-customization-service/v1/customize)(?:\?|$), accept-encoding
0, 1, ^/(?:bootstrap/v1/bootstrap|user-customization-service/v1/customize)(?:\?|$), accept-encoding, identity
0, 0, "(^/(?:artistview/v1/artist|album-entity-view/v2/album)/.*[?&]platform=)iphone", $1ipad
1, 4, ^/(?:bootstrap/v1/bootstrap|user-customization-service/v1/customize)(?:\?|$), 
